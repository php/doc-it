<refentry xml:id="function.gmp-powm" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>gmp_powm</refname>
  <refpurpose>Eleva un numero a potenza con modulo</refpurpose>
 </refnamediv>
 
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>GMP</type><methodname>gmp_powm</methodname>
   <methodparam><type class="union"><type>GMP</type><type>int</type><type>string</type></type><parameter>num</parameter></methodparam>
   <methodparam><type class="union"><type>GMP</type><type>int</type><type>string</type></type><parameter>exponent</parameter></methodparam>
   <methodparam><type class="union"><type>GMP</type><type>int</type><type>string</type></type><parameter>modulus</parameter></methodparam>
  </methodsynopsis>
  <para>
   Calcola (<parameter>num</parameter> elevato alla potenza
   <parameter>exponent</parameter>) modulo <parameter>modulus</parameter>. Se
   <parameter>exponent</parameter> è negativo, il risultato non è definito.
  </para>
 </refsect1>


 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>num</parameter></term>
     <listitem>
      <para>
       Il numero base.
      </para>
      &gmp.parameter; 
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>exponent</parameter></term>
     <listitem>
      <para>
       La potenza positiva a cui elevare <parameter>num</parameter>.
      </para>
      &gmp.parameter; 
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>modulus</parameter></term>
     <listitem>
      <para>
       Il modulo.
      </para>
      &gmp.parameter; 
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>
   Il nuovo numero (elevato a potenza), come numero GMP.
  </para>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <para>
   <example>
    <title>Esempio di <function>gmp_powm</function></title>
    <programlisting role="php">
<![CDATA[
<?php
$pow1 = gmp_powm("2", "31", "2147483649");
echo gmp_strval($pow1) . "\n";
?>
]]>
    </programlisting>
    &example.outputs;
    <screen>
<![CDATA[
2147483648
]]>
    </screen>
   </example>
  </para>
 </refsect1>

</refentry>
